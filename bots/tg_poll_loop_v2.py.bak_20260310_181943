import os,time,subprocess,pathlib

ROOT=pathlib.Path("/Users/doyopc/AI/openclaw-factory-daemon")
LOG=ROOT/"logs"/"tg_poll.log"
ERR=ROOT/"logs"/"tg_poll.err"

BOTS=[
    "bots/ingest_telegram_replies_v1.py",
    "bots/ingest_spec_answers_v1.py",
    "bots/meeting_orchestrator_v1.py",
    "bots/company_dashboard_v1.py",
    "bots/ceo_help_v1.py",
    "bots/ceo_noise_cleanup_v1.py",
    "bots/report_orchestrator_v1.py",
    "bots/explain_orchestrator_v1.py",
    "bots/ceo_hub_sender_v1.py",
]

def load_env():
    env=os.environ.copy()
    env["PYTHONUNBUFFERED"]="1"
    env["PYTHONPATH"]=str(ROOT)
    env["DB_PATH"]=str(ROOT/"data"/"openclaw_real.db")
    env["FACTORY_DB_PATH"]=str(ROOT/"data"/"openclaw_real.db")

    for fp in [
        ROOT/"env"/"telegram_replies.env",
        ROOT/"env"/"telegram_report.env",
        pathlib.Path("/Users/doyopc/AI/openclaw-factory/env/openai.env"),
    ]:
        if not fp.exists():
            continue
        for line in fp.read_text(encoding="utf-8").splitlines():
            line=line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line=line[7:]
            if "=" not in line:
                continue
            k,v=line.split("=",1)
            env[k.strip()]=v.strip()

    if env.get("TELEGRAM_REPORT_BOT_TOKEN"):
        env["TELEGRAM_BOT_TOKEN"]=env["TELEGRAM_REPORT_BOT_TOKEN"]
    if env.get("CEO_CHAT_ID"):
        env["TELEGRAM_CHAT_ID"]=env["CEO_CHAT_ID"]
    return env

def run_one(bot, env):
    with LOG.open("a", encoding="utf-8") as out, ERR.open("a", encoding="utf-8") as err:
        out.write(f"[{time.strftime('%F %T')}] {bot}\n")
        out.flush()
        subprocess.run(
            [str(ROOT/".venv/bin/python"), "-u", str(ROOT/bot)],
            cwd=str(ROOT),
            env=env,
            stdin=subprocess.DEVNULL,
            stdout=out,
            stderr=err,
            check=False,
        )

def main():
    ROOT.joinpath("logs").mkdir(parents=True, exist_ok=True)
    while True:
        env=load_env()
        for bot in BOTS:
            run_one(bot, env)
        time.sleep(2)

if __name__=="__main__":
    main()
